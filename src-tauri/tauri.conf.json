{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dictum",
  "version": "0.1.0",
  "identifier": "io.latticelabs.dictum",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3003",
    "beforeDevCommand": {
      "script": "bun run dev",
      "wait": false
    },
    "beforeBuildCommand": "bun run build:static"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Dictum",
        "url": "/app",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "category": "Productivity",
    "shortDescription": "Private, on-device voice-to-text.",
    "longDescription": "Dictum transcribes your voice locally with Whisper. Your audio never leaves the device.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 430, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  }
}
